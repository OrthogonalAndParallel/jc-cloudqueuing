<view class="card">
  <view class="row">
    <view>队列</view>
    <input value="{{queueId}}" placeholder="default" bindinput="onQueueIdInput" style="text-align:right" />
  </view>

  <button class="btn" bindtap="onRefresh">刷新队列</button>

  <view class="muted" style="margin-top:8px;">最后刷新：{{lastUpdatedText}}</view>
</view>

<view class="card">
  <view>队列概览</view>
  <view style="margin-top:8px;">等待中：{{waitingCountText}}</view>
  <view style="margin-top:8px;">已叫号：{{calledCountText}}</view>
  <view style="margin-top:8px;">已取消：{{canceledCountText}}</view>
</view>

<view class="card">
  <view>队列明细</view>

  <view wx:if="{{items.length === 0}}" class="muted" style="margin-top:8px;">
    暂无数据
  </view>

  <view wx:for="{{items}}" wx:key="id" style="padding:10px 0; border-bottom: 1px solid #eee;">
    <view class="row">
      <view>{{index + 1}}. {{item.nickname || item.userId}}</view>
      <view class="muted">{{item.status}}</view>
    </view>
    <view class="muted" style="margin-top:6px;">开始时间: {{item.createdAtText}}</view>
    <view class="muted" style="margin-top:6px;">userId: {{item.userId}}</view>
  </view>
</view>
